{
  "name": "wealthybiz-accounting",
  "version": "1.0.0",
  "description": "wealthyBIZ Accounting Software - Tally Alternative for Indian Businesses",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "wealthyBIZ",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.0",
    "sqlite3": "^5.1.6",
    "better-sqlite3": "^9.2.0",
    "xlsx": "^0.18.5",
    "jspdf": "^2.5.1",
    "html2canvas": "^1.4.1",
    "recharts": "^2.10.0",
    "tailwindcss": "^3.4.0",
    "date-fns": "^2.30.0",
    "uuid": "^9.0.1",
    "electron-store": "^8.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "electron-dev-utils": "^1.1.0",
    "concurrently": "^8.2.1",
    "wait-on": "^7.2.0"
  },
  "scripts": {
    "react-start": "vite",
    "react-build": "vite build",
    "electron-start": "electron .",
    "electron-dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:5173 && npm run electron-start\"",
    "electron-build": "npm run react-build && electron-builder",
    "start": "npm run electron-dev",
    "build": "npm run electron-build",
    "dist": "npm run build -- --publish never"
  },
  "build": {
    "appId": "com.wealthybiz.accounting",
    "productName": "wealthyBIZ Accounting",
    "files": [
      "dist/**/*",
      "public/electron.js",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "wealthyBIZ Accounting"
    }
  }
}
